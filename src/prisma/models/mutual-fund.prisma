model MfProduct {
    id                    String  @id @default(uuid())
    scheme_code           String  @unique
    scheme_name           String
    fund_house            String
    scheme_type           String
    scheme_category       String
    isin_growth           String?
    isin_div_reinvestment String?

    // Nested object flattened into two fields
    latest_nav      String?
    latest_nav_date DateTime

    // timestamp DateTime @default(now())
    last_synced_at DateTime @default(now()) @updatedAt
    createdAt      DateTime @default(now())
    updatedAt      DateTime @default(now()) @updatedAt

    // Relations
    nav_history MfNav[]
    metrics     MfMetrics?

    @@index([fund_house])
    @@index([scheme_category])
    @@index([latest_nav_date])
}

model MfNav {
    id            String   @id @default(uuid())
    mf_product_id String
    scheme_code   String
    nav_date      DateTime
    nav_value     String

    last_synced_at DateTime @default(now()) @updatedAt
    createdAt      DateTime @default(now())
    updatedAt      DateTime @default(now()) @updatedAt

    // Relations
    mf_product MfProduct @relation(fields: [mf_product_id], references: [id], onDelete: Cascade)

    @@unique([scheme_code, nav_date])
    @@index([scheme_code, nav_date])
    @@index([mf_product_id, nav_date])
}

model MfMetrics {
    id            String @id @default(uuid())
    mf_product_id String @unique

    return_1m Decimal @db.Decimal(6, 2)
    return_6m Decimal @db.Decimal(6, 2)
    return_1y Decimal @db.Decimal(6, 2)
    return_3y Decimal @db.Decimal(6, 2)
    return_5y Decimal @db.Decimal(6, 2)

    createdAt DateTime @default(now())
    updatedAt DateTime @default(now()) @updatedAt

    // Relations
    mf_product MfProduct @relation(fields: [mf_product_id], references: [id], onDelete: Cascade)

    @@index([mf_product_id])
}
